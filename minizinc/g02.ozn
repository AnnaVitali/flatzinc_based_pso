output ["x = ",showDzn(x),";\n","cos2_x = ",showDzn(cos2_x),";\n","prefix_prod_cos2 = ",showDzn(prefix_prod_cos2),";\n","prefix_prod_x = ",showDzn(prefix_prod_x),";\n"];
int: n = 20;
array [1..n] of float: prefix_prod_x;
array [1..n] of float: prefix_prod_cos2;
array [1..n] of float: cos2_x;
array [1..n] of float: x;
